direction: down

diagram_title: "C4 Component\nExample App" {
  near: top-left
  style: {
    fill: transparent
    stroke: transparent
    bold: true
    font-size: 20
  }
}

layout_rows: "" {
  grid-rows: 2
  vertical-gap: 10
  style.fill: transparent
  style.stroke: transparent

  external: "External actors/systems" {
    grid-columns: 3
    horizontal-gap: 30

    browser: "Browser"
    oidc: "OIDC Provider"
    letsencrypt: "Let's Encrypt\n(ACME)"
  }

  app_path: "App request path" {
    grid-columns: 3
    horizontal-gap: 44

    edge: "Ingress edge" {
      grid-rows: 3
      traefik_entry: "Traefik router"
      oauth_mw: "oauth-auth-shared middleware"
      oauth_proxy: "oauth2-proxy-shared service"
    }

    app_stack: "hello-web app stack" {
      grid-rows: 3
      ingress: "hello-web ingress"
      service: "hello-web service"
      deployment: "hello-web deployment"
    }

    certs: "TLS automation" {
      grid-rows: 2
      cert_manager: "cert-manager"
      cert: "hello-web certificate"
    }
  }
}

layout_rows.external.browser -> layout_rows.app_path.edge.traefik_entry: "HTTPS request"
layout_rows.app_path.edge.traefik_entry -> layout_rows.app_path.edge.oauth_mw
layout_rows.app_path.edge.oauth_mw -> layout_rows.app_path.edge.oauth_proxy
layout_rows.app_path.edge.oauth_proxy -> layout_rows.external.oidc: "OIDC login/token"
layout_rows.app_path.edge.oauth_proxy -> layout_rows.app_path.edge.oauth_mw
layout_rows.app_path.edge.traefik_entry -> layout_rows.app_path.app_stack.ingress: "Route host/path"
layout_rows.app_path.app_stack.ingress -> layout_rows.app_path.app_stack.service
layout_rows.app_path.app_stack.service -> layout_rows.app_path.app_stack.deployment

layout_rows.app_path.certs.cert_manager -> layout_rows.app_path.certs.cert
layout_rows.app_path.certs.cert_manager -> layout_rows.external.letsencrypt: "ACME challenge"
layout_rows.app_path.certs.cert -> layout_rows.app_path.app_stack.ingress: "TLS secret"
