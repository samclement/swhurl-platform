direction: down

diagram_title: "C4 Context\nSwhurl Platform" {
  near: top-left
  style: {
    fill: transparent
    stroke: transparent
    bold: true
    font-size: 20
  }
}

layout_rows: "" {
  grid-rows: 2
  vertical-gap: 10
  style.fill: transparent
  style.stroke: transparent

  external: "External actors/systems" {
    grid-columns: 3
    horizontal-gap: 28

    a_control: "Control & delivery" {
      grid-rows: 2
      github: "GitHub Repo\nswhurl-platform"
      route53: "Route53 DNS"
    }

    b_actors: "Human actors" {
      grid-rows: 2
      operator: "Platform Operator"
      end_user: "App End User"
    }

    c_providers: "Identity/TLS providers" {
      grid-rows: 2
      oidc: "OIDC Provider\n(Google)"
      letsencrypt: "Let's Encrypt\n(ACME)"
    }
  }

  platform: "Swhurl Platform\n(k3s + Flux + platform services)" {
    style.fill: "#E8F3FF"
  }
}

layout_rows.external.b_actors.operator -> layout_rows.external.a_control.github: "Commit manifests"
layout_rows.external.a_control.github -> layout_rows.platform: "Flux reconcile"
layout_rows.external.b_actors.operator -> layout_rows.platform: "Operate platform"

layout_rows.external.b_actors.end_user -> layout_rows.external.a_control.route53: "Resolve DNS"
layout_rows.external.a_control.route53 -> layout_rows.platform: "Ingress routing"
layout_rows.external.b_actors.end_user -> layout_rows.platform: "HTTPS requests"

layout_rows.platform -> layout_rows.external.c_providers.oidc: "OIDC auth"
layout_rows.platform -> layout_rows.external.c_providers.letsencrypt: "ACME issuance"
